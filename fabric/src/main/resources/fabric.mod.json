{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://modrinth.com/mod/adventure-zones",
        "issues": "https://github.com/gimme/adventure-zones/issues",
        "sources": "https://github.com/gimme/adventure-zones"
    },
    "license": "${license}",
    "environment": "server",
    "entrypoints": {
        "main": [
            "dev.gimme.adventurezones.fabric.FabricMod"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}",
        "forgeconfigapiport": ">=${forge_config_api_port_version}"
    },
    "custom": {
        "mc-publish": {
            "dependencies": [
                "forgeconfigapiport(required){modrinth:forge-config-api-port}{curseforge:forge-config-api-port}"
            ]
        }
    }
}
